rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny ALL
    match /{document=**} {
      allow read, write: if false;
    }

    match /joinRequests/{requestId} {
      allow read: if true; // anyone can read 
      allow create: if true; // anyone can request
      allow update: if true; // admins can update status
      allow delete: if request.auth != null; // admins
    }

    match /tiktokPosts/{postId} {
      allow read: if true; 
      allow write: if true; 
    }

    match /designers/{designerId} {
      allow read: if true;
      allow write: if true;
    }

    match /staff/{staffId} {
      allow read: if true;
      allow write: if true;
    }

    match /withdrawals/{withdrawalId} {
      allow read: if true;
      allow write: if true;
    }

    match /adminLogs/{logId} {
      allow read: if true;
      allow write: if true;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }

    match /stats/{statId} {
      allow read: if true;
      allow write: if true;
    }

    match /system/{systemId} {
      allow read: if true;
      allow write: if true;
    }
    match /kickClips/{clipId} {
      allow read: if true;
      allow write: if true;
    }
    match /top3Designers/{designerId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
